# 须指向跑「完整」server/index.js 的域名（含 /api/auth、/api/pay 等）。仅部署支付的子域会导致 /api/auth 404。
VITE_PAY_API_BASE=https://ai.syzs.top
# 登录弹窗「其他方式」OAuth 图标占位（设为 1 或 true 才显示；后端未接好时点击为「即将开放」）
# VITE_LOGIN_OAUTH_GITHUB=1
# VITE_LOGIN_OAUTH_GOOGLE=1
# 定制服务提交后展示（可选）
# VITE_WECHAT_ID=你的微信号
# VITE_WECHAT_QR_URL=https://example.com/wechat-qr.png
