# 复制为 .env 后填入真实值（server/.env 已加入 .gitignore）
PORT=8787

# 管理端 /api/admin Bearer 校验（与前端 VITE_ADMIN_API_BEARER 一致）
ADMIN_PASSWORD=Aike@2026#Ai

# 支付宝开放平台 — 应用信息
ALIPAY_APP_ID=2021006147683807
# 应用私钥（PKCS8 一行或多行，换行可用 \n 转义）
ALIPAY_PRIVATE_KEY=
ALIPAY_KEY_TYPE=PKCS8

# 公钥证书模式（推荐）：三份证书放到 server/cert/ 下
ALIPAY_APP_CERT_PATH=./cert/appCertPublicKey.crt
ALIPAY_PUBLIC_CERT_PATH=./cert/alipayCertPublicKey_RSA2.crt
ALIPAY_ROOT_CERT_PATH=./cert/alipayRootCert.crt

# 或公钥模式（二选一）：填写支付宝公钥字符串，并删除上面三个证书路径
# ALIPAY_PUBLIC_KEY=

# 沙箱网关（沙箱联调时取消注释）
# ALIPAY_GATEWAY=https://openapi.alipaydev.com/gateway.do
# ALIPAY_ENDPOINT=https://openapi.alipaydev.com

# 公网域名（与线上部署一致）
PUBLIC_API_ORIGIN=https://ai.syzs.top
FRONTEND_PUBLIC_URL=https://ai.syzs.top

# 支付宝同步跳转：先到后端验签，再 302 到前端 /pay/success
SYNC_RETURN_URL=https://ai.syzs.top/api/pay/callback

# 支付宝异步通知
NOTIFY_URL=https://ai.syzs.top/api/pay/notify

# Anthropic（/jobs 就业雷达 · Claude 深度报告，可选；未配置时接口返回错误，前端走兜底文案）
# ANTHROPIC_API_KEY=

# ─── 就业雷达 · 实时岗位 API（/api/jobs/search）────────────────────────
# 职得看（主）：商务开通后填写；未配置时搜索返回本地示例数据
# ZHIDEKAN_API_KEY=
# ZHIDEKAN_API_BASE=https://api.zhidekan.com/v1
# ZHIDEKAN_JOBS_PATH=/jobs/search
# ZHIDEKAN_API_HEADER=X-Api-Key
# 猎聘（备）：需企业开发者 access_token；路径以开放平台文档为准
# LIEPIN_ACCESS_TOKEN=
# LIEPIN_APP_SECRET=
# LIEPIN_API_BASE=https://open.liepin.com
# LIEPIN_JOBS_PATH=/api/com.liepin.search.job.search
# JOBS_SEARCH_CACHE_TTL_MS=1800000
# JOBS_SEARCH_RATE_MAX=20
# JOBS_UPSTREAM_TIMEOUT_MS=8000

# 热门技能快照：定时任务 npm run jobs:refresh-hot-skills 拉取各关键词岗位数写入 SQLite；
# GET /api/jobs/hot-skills 优先读库，无数据时用静态兜底。
# JOBS_HOT_SKILLS_CITY=全国
# 建议 crontab（每天 2:00，路径按部署修改）：
#   0 2 * * * cd /path/to/Aike/server && npm run jobs:refresh-hot-skills >> /var/log/aike-hot-skills.log 2>&1
# 或管理端 Bearer 调用：POST /api/admin/jobs/refresh-hot-skills（与脚本等价）

# ─── 阿里云短信（创作者登录 /api/creator/send-code）────────────────
# 控制台：https://dysms.console.aliyun.com  创建签名 + 验证码模板（变量名常用 code）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
# 可选：模板变量名不是 code 时设置，例如 template 里是 ${number} 则填 number
# ALIYUN_SMS_CODE_PARAM=code
# 可选：endpoint 默认 dysmsapi.aliyuncs.com
# ALIYUN_SMS_ENDPOINT=dysmsapi.aliyuncs.com

# 开发环境可选：与验证码相等时免短信直连登录（勿用于生产）
# CREATOR_DEV_SMS_CODE=

# ─── 登录 / NODE_ENV ─────────────────────────────────────────────
# 服务端 NODE_ENV 非 production 时：/api/creator/send-code 不调阿里云，固定下发 888888；
# 生产环境必须配置上方阿里云短信，否则返回 503。
# NODE_ENV=production

# 前台邮箱验证码（生产）：需 nodemailer + 下列 SMTP（开发环境邮箱码固定 888888）
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# 微信网站应用扫码登录（可选；未配置时接口返回 configured:false）
# WECHAT_WEB_APP_ID=
# WECHAT_WEB_APP_SECRET=
# WECHAT_WEB_REDIRECT_URI=https://你的API域名/api/auth/wechat-callback

# 邮箱/微信登录签发 JWT（可选，默认与 CREATOR_JWT_SECRET 相同）
# SITE_JWT_SECRET=
# CREATOR_JWT_SECRET=

# ─── 分销本地测试快速配置（步骤见仓库根目录 TESTING.md）──────────────
# 开启模拟支付（跳过支付宝；本地测试建议与 NODE_ENV=development 联用以固定短信码）
# PAY_DEV_SIMULATE=1
#
# 佣金结算等待天数：0 表示支付后立即可提现
# DISTRIBUTION_SETTLE_DAYS=0
#
# 最低提现金额（元）
# DISTRIBUTION_WITHDRAW_MIN_YUAN=10
#
# 是否要求推广人必须是已审核的创作者（测试时设为 0）
# DISTRIBUTION_REQUIRE_CREATOR_APPROVED=0
#
# 前端访问地址（用于生成推广链接，必须与 Vite 端口一致）
# FRONTEND_PUBLIC_URL=http://localhost:5174
